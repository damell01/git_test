# Restrict to PHP files only — no directory listing
Options -Indexes

# Only allow access to specific PHP API files
<FilesMatch "^(contact|availability|create-booking|stripe-webhook)\.php$">
  Require all granted
</FilesMatch>

<FilesMatch "^(?!(contact|availability|create-booking|stripe-webhook)\.php$)">
  Require all denied
</FilesMatch>
