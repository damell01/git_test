# Root .htaccess — Trash Panda Roll-Offs
# Ensures that visiting the bare domain URL transparently serves the public
# website housed in the /public/ directory (URL stays at domain root).

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Serve the public website home page for the bare domain root
    RewriteRule ^$ public/index.html [L]

    # For any path that is NOT already under /public/ or /admin/,
    # check whether the file or directory exists inside /public/ and
    # transparently serve it from there (no URL change for the visitor).
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteCond %{REQUEST_URI} !^/admin/
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f [OR]
    RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -d
    RewriteRule ^(.+)$ public/$1 [L]
</IfModule>
