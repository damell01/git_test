# ─────────────────────────────────────────────────────────────────────────────
# Trash Panda Roll-Offs — Environment Configuration
#
# Copy this file to .env in the project root and fill in your values.
#   cp .env.example .env
#
# .env is listed in .gitignore and will NOT be committed to source control.
# Never commit real credentials to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_NAME=trashpanda
DB_USER=trashpanda_user
DB_PASS=replace-with-strong-password
DB_CHARSET=utf8mb4

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=Trash Panda Roll-Offs
APP_VERSION=1.0.0

# Set to true ONLY during local development — reveals full error traces.
APP_DEBUG=false

# Set to true after running the installer (admin/install/install.php).
APP_INSTALLED=true

# Session lifetime in seconds (default: 7200 = 2 hours)
SESSION_LIFETIME=7200

# ── Security ──────────────────────────────────────────────────────────────────
# Replace with a long random secret (e.g. openssl rand -hex 32).
# Used to authenticate scheduled cron requests via the web endpoint.
CRON_KEY=replace-with-a-random-secret
