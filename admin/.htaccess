# Prevent directory listing
Options -Indexes

# Block access to sensitive files
<FilesMatch "\.(sql|log|env|json|md|lock)$">
  Require all denied
</FilesMatch>

# Block access to sensitive server-side directories
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^(includes|config|cron)/.*$ - [F,L]
</IfModule>

# Force HTTPS (uncomment when SSL is active)
# <IfModule mod_rewrite.c>
#   RewriteCond %{HTTPS} off
#   RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
# </IfModule>
